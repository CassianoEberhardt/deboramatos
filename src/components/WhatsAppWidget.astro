---
import { INSTAGRAM_URL, WHATSAPP_URL } from '../consts';
---

<div class="wa-widget wa-widget--open">
  <div class="wa-widget__popup" id="wa-popup" role="dialog" aria-label="Conversar pelo WhatsApp">
    <button class="wa-widget__close" type="button" aria-label="Minimizar conversa">×</button>
    <div class="wa-widget__header">
      <span class="wa-widget__avatar" aria-hidden="true">DM</span>
      <span>
        <strong>Débora Matos</strong>
        <small>Psicóloga · atendimento online</small>
      </span>
    </div>
    <p class="wa-widget__bubble">
      Olá! 👋 Quer conversar sobre terapia? Me chama no WhatsApp — respondo assim que puder.
    </p>
    <a class="btn btn--whatsapp wa-widget__cta" href={WHATSAPP_URL} target="_blank" rel="noopener">
      Iniciar conversa
    </a>
  </div>

  <button
    class="wa-widget__fab"
    type="button"
    aria-expanded="true"
    aria-controls="wa-popup"
    aria-label="Abrir conversa do WhatsApp"
  >
    <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor" aria-hidden="true">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
      ></path>
    </svg>
  </button>

  <a
    class="wa-widget__instagram"
    href={INSTAGRAM_URL}
    target="_blank"
    rel="noopener"
    aria-label="Seguir no Instagram (@matosdebora)"
  >
    <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true">
      <path
        d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.794.646-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439z"
      ></path>
    </svg>
  </a>
</div>

<style>
  .wa-widget {
    position: fixed;
    right: var(--space-4);
    bottom: var(--space-4);
    z-index: 90;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-3);
  }

  /* Balão de conversa */
  .wa-widget__popup {
    width: min(20rem, calc(100vw - 2rem));
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    border-bottom-right-radius: var(--radius-sm);
    box-shadow: var(--shadow-lg);
    padding: var(--space-4);
    transform-origin: bottom right;
    transition:
      opacity 300ms ease,
      translate 300ms ease,
      scale 300ms ease;
  }

  .wa-widget:not(.wa-widget--open) .wa-widget__popup {
    opacity: 0;
    translate: 0 12px;
    scale: 0.92;
    pointer-events: none;
  }

  .wa-widget__close {
    position: absolute;
    top: var(--space-2);
    right: var(--space-3);
    border: 0;
    background: none;
    font-size: 1.4rem;
    line-height: 1;
    color: var(--text-muted);
    cursor: pointer;
  }

  .wa-widget__close:hover {
    color: var(--text);
  }

  .wa-widget__header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-right: var(--space-6);
  }

  .wa-widget__header small {
    display: block;
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .wa-widget__avatar {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    border-radius: var(--radius-pill);
    background: var(--brand-600);
    color: var(--brand-50);
    font-family: var(--font-display);
    font-weight: 700;
  }

  .wa-widget__bubble {
    margin-top: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--bg);
    border-radius: var(--radius-md);
    border-top-left-radius: var(--radius-sm);
    font-size: var(--fs-small);
  }

  .wa-widget__cta {
    margin-top: var(--space-3);
    width: 100%;
    justify-content: center;
    font-size: var(--fs-small);
  }

  /* Botão redondo com anel pulsante */
  .wa-widget__fab {
    position: relative;
    display: grid;
    place-items: center;
    width: 3.5rem;
    height: 3.5rem;
    border: 0;
    border-radius: var(--radius-pill);
    background: var(--whatsapp-dark);
    color: #fff;
    cursor: pointer;
    box-shadow: var(--shadow-md);
    transition: transform 200ms ease;
  }

  .wa-widget__fab:hover {
    transform: scale(1.08);
  }

  .wa-widget__fab:active {
    transform: scale(0.94);
  }

  .wa-widget__fab::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--whatsapp);
    z-index: -1;
    animation: wa-pulse 2.2s ease-out infinite;
  }

  @keyframes wa-pulse {
    0% {
      transform: scale(1);
      opacity: 0.55;
    }
    80%,
    100% {
      transform: scale(1.75);
      opacity: 0;
    }
  }

  /* Botão do Instagram — mesmo tamanho do WhatsApp, gradiente da marca.
     Sem anel pulsante de propósito: o WhatsApp é a conversão principal. */
  .wa-widget__instagram {
    display: grid;
    place-items: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-pill);
    background: radial-gradient(
      circle at 30% 110%,
      #fdf497 0%,
      #fd5949 45%,
      #d6249f 60%,
      #285aeb 90%
    );
    color: #fff;
    box-shadow: var(--shadow-md);
    transition: transform 200ms ease;
  }

  .wa-widget__instagram:hover {
    transform: scale(1.08);
    color: #fff;
  }

  .wa-widget__instagram:active {
    transform: scale(0.94);
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-widget__fab::before {
      animation: none;
    }
  }
</style>

<script>
  const widget = document.querySelector('.wa-widget');
  const fab = widget?.querySelector('.wa-widget__fab');
  const close = widget?.querySelector('.wa-widget__close');

  const setOpen = (open: boolean) => {
    widget?.classList.toggle('wa-widget--open', open);
    fab?.setAttribute('aria-expanded', String(open));
    fab?.setAttribute('aria-label', open ? 'Minimizar conversa do WhatsApp' : 'Abrir conversa do WhatsApp');
  };

  fab?.addEventListener('click', () => setOpen(!widget?.classList.contains('wa-widget--open')));
  close?.addEventListener('click', () => setOpen(false));
</script>
