---
import { WHATSAPP_URL } from '../consts';

// M1: navegação por âncoras sempre visível (rolagem horizontal no mobile).
// O menu hambúrguer acessível entra no Marco 2.
// Âncoras com "/" na frente para funcionarem também fora da home (ex.: /privacidade).
const links = [
  { href: '/#sobre', label: 'Sobre' },
  { href: '/#tcc', label: 'TCC' },
  { href: '/#sessoes', label: 'Sessões' },
  { href: '/#para-quem', label: 'Para quem' },
  { href: '/#faq', label: 'Dúvidas' },
];
---

<header class="header">
  <div class="container header__inner">
    <a class="header__logo" href="/#inicio">
      Débora Matos <span>Psicóloga</span>
    </a>
    <nav aria-label="Navegação principal">
      <ul class="header__nav">
        {
          links.map(({ href, label }) => (
            <li>
              <a href={href}>{label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a class="btn btn--primary header__cta" href={WHATSAPP_URL} target="_blank" rel="noopener">
      Conversar
    </a>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
    transition: box-shadow 300ms ease;
  }

  .header--scrolled {
    box-shadow: var(--shadow-md);
  }

  .header__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-6);
    padding-block: var(--space-3);
  }

  .header__logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--brand-700);
    text-decoration: none;
  }

  .header__logo span {
    display: block;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .header__nav {
    display: flex;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
    list-style: none;
    overflow-x: auto;
  }

  .header__nav a {
    position: relative;
    display: inline-block;
    padding: var(--space-2) var(--space-1); /* área de toque maior no celular */
    color: var(--text);
    text-decoration: none;
    font-size: var(--fs-small);
    white-space: nowrap;
    transition: color 200ms ease;
  }

  /* Sublinhado dentro da caixa do link (bottom >= 0): fora dela ele gera
     overflow na lista rolável e faz aparecer barras de rolagem no hover */
  .header__nav a::after {
    content: '';
    position: absolute;
    left: var(--space-1);
    right: var(--space-1);
    bottom: 2px;
    height: 2px;
    border-radius: 1px;
    background: var(--brand-500);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 250ms ease;
  }

  .header__nav a:hover {
    color: var(--brand-600);
  }

  .header__nav a:hover::after {
    transform: scaleX(1);
  }

  .header__cta {
    margin-left: auto;
    padding: var(--space-2) var(--space-4);
    font-size: var(--fs-small);
  }

  /* Mobile: logo + CTA na primeira linha, nav na segunda, ocupando a
     largura toda. A fonte encolhe junto com a tela (clamp) para os 5
     links caberem inteiros; a rolagem fica só como última defesa, sem
     barra visível. */
  @media (max-width: 767px) {
    nav {
      order: 3;
      width: 100%;
    }

    .header__nav {
      justify-content: space-between;
      gap: var(--space-2);
      font-size: clamp(0.6875rem, 3.4vw, 0.875rem);
      scrollbar-width: none;
    }

    .header__nav::-webkit-scrollbar {
      display: none;
    }

    .header__nav a {
      font-size: inherit;
      padding-inline: 2px;
    }
  }

  /* Desktop: menu centralizado entre o logo e o CTA, sem rolagem */
  @media (min-width: 768px) {
    nav {
      flex: 1;
    }

    .header__nav {
      overflow: visible;
      justify-content: center;
    }
  }
</style>
